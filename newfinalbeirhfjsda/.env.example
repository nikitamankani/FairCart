# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/faircart
# OR use MongoDB Atlas:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/faircart

# JWT Secret — change this to any long random string before deploying!
JWT_SECRET=faircart_super_secret_jwt_key_change_me_in_production
JWT_EXPIRES_IN=7d

# Server
PORT=5000
CLIENT_URL=http://localhost:3000

# SerpAPI — get your free key at https://serpapi.com
# Leave blank to use mock database (100 free searches/month on free plan)
SERP_API_KEY=
